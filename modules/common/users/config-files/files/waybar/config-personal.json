{
  "layer": "top",
  "position": "top",
  "height": 42,
  "spacing": 8,
  "modules-left": [
    "custom/notification",
    "pulseaudio",
    "battery",
    "clock",
    "hyprland/submap",
    "hyprland/workspaces"
  ],
  "modules-center": [],
  "modules-right": ["hyprland/window", "tray"],

  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "’éó<span foreground='#ff006e'><sup>’æä</sup></span>",
      "none": "’éó",
      "dnd-notification": "’ćĘ<span foreground='#ff006e'><sup>’æä</sup></span>",
      "dnd-none": "’ćĘ",
      "inhibited-notification": "’éó<span foreground='#ff006e'><sup>’æä</sup></span>",
      "inhibited-none": "’éó",
      "dnd-inhibited-notification": "’ćĘ<span foreground='#ff006e'><sup>’æä</sup></span>",
      "dnd-inhibited-none": "’ćĘ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "on-click": "activate",
    "sort-by-number": true,
    "disable-scroll": true,
    "format-icons": {
      "1": "1 web",
      "2": "2 code",
      "3": "3 term",
      "4": "4 chat",
      "5": "5 docs",
      "6": "6 media",
      "7": "7 admin",
      "8": "8 scratch",
      "9": "9 remote",
      "10": "10 temp"
    },
    "persistent-workspaces": {
      "1": 1,
      "2": 1,
      "3": 1,
      "4": 1,
      "5": 1,
      "6": 1,
      "7": 1,
      "8": 1,
      "9": 1,
      "10": 1
    }
  },

  "hyprland/submap": {
    "format": "mode {}",
    "max-length": 24,
    "tooltip": false
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 72,
    "rewrite": {
      "": "desktop"
    },
    "separate-outputs": true
  },

  "clock": {
    "format": "¾▒æå  {:%I:%M %p}",
    "format-alt": "¾░āŁ  {:%A, %B %d, %Y}",
    "tooltip-format": "<tt><small>{calendar}</small></tt>",
    "on-click": "mode",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ff006e'><b>{}</b></span>",
        "days": "<span color='#e0e0e0'><b>{}</b></span>",
        "weeks": "<span color='#9d4edd'><b>W{}</b></span>",
        "weekdays": "<span color='#00f0ff'><b>{}</b></span>",
        "today": "<span color='#ffea00'><b><u>{}</u></b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  "battery": {
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-charging": "’ā¦  {capacity}%",
    "format-plugged": "’ć”  {capacity}%",
    "format-alt": "{capacity}%",
    "format-icons": ["¾░ü║", "¾░ü╗", "¾░ü╝", "¾░üĮ", "¾░üŠ", "¾░ü┐", "¾░éĆ", "¾░éü", "¾░éé", "¾░ü╣"],
    "tooltip-format": "{timeTo}\n{capacity}%",
    "on-click": "~/.config/hypr/scripts/power-menu.sh",
    "on-click-right": "swaync-client -t -sw"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-bluetooth": "’Ŗö  {volume}%",
    "format-bluetooth-muted": "’Ü®  bt",
    "format-muted": "’Ü®  mute",
    "format-icons": {
      "headphone": "’Ćź",
      "hands-free": "’¢É",
      "headset": "’¢É",
      "phone": "’éĢ",
      "portable": "’éĢ",
      "car": "’å╣",
      "default": ["’Ć”", "’Ć¦", "’Ć©"]
    },
    "on-click": "swaync-client -t -sw",
    "on-click-right": "pavucontrol",
    "tooltip-format": "{desc}\n{volume}%",
    "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+",
    "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-"
  },

  "tray": {
    "icon-size": 18,
    "spacing": 8
  }
}
