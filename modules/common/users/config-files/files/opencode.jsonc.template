{
  "$schema": "https://opencode.ai/config.json",
  "theme": "opencode",
  "model": "opencode/gpt-5.2-codex",
  "autoupdate": true,
  "permission": {
    "websearch": "deny",
    "skill": {
      "*": "allow"
    },
    "external_directory": {
      "~/Workspace/**": "allow"
    },
    "edit": {
      "~/Workspace/**": "deny"
    },
  },
  "tui": {
    "scroll_acceleration": {
      "enabled": true,
    },
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["mcp-server-playwright"],
      "enabled": true,
    },
    "chrome_devtools": {
      "type": "local",
      "command": ["npx", "chrome-devtools-mcp@latest"],
      "enabled": true,
    },
    "nixos": {
      "type": "local",
      "command": ["uvx", "mcp-nixos"],
      "enabled": true,
    },
    "nushell": {
      "type": "local",
      "command": ["nu", "--mcp"],
      "enabled": true,
    },
    "datadog": {
      "type": "local",
      "command": ["{{DATADOG_MCP_CLI_PATH}}"],
      "enabled": {{DATADOG_MCP_ENABLED}},
      "environment": {},
    },
    "pencil": {
      "type": "local",
      "command": [
        "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
        "--app",
        "desktop"
      ],
      "enabled": {{PENCIL_MCP_ENABLED}},
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
    },
    "kagi": {
      "type": "local",
      "command": ["uvx", "kagimcp"],
      "environment": {
        "KAGI_API_KEY": "{{KAGI_API_KEY_PLACEHOLDER_REPLACE_AT_BUILD_TIME}}",
      },
    },
  },
}
